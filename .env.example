# ---- Postgres ----
POSTGRES_USER=sms
POSTGRES_PASSWORD=sms
POSTGRES_DB=sms
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379

# ---- Backend (api + worker share this image) ----
# Port the service listens on INSIDE the container.
API_PORT=3000
# Port published on the host (change if 3000 is taken locally).
API_HOST_PORT=3000
# production => structured JSON logs; development => pretty logs (needs dev deps / local tsx)
NODE_ENV=production
LOG_LEVEL=info

# Connection strings (host names resolve inside the compose network)
DATABASE_URL=postgres://sms:sms@postgres:5432/sms
REDIS_URL=redis://redis:6379

# Twilio (mocked by Mountebank)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=local-test-auth-token
TWILIO_FROM_NUMBER=+15550000000
# Outbound Twilio REST API base -> Mountebank imposter
TWILIO_API_BASE_URL=http://mountebank:4545

# ---- Async processing ----
WORKER_CONCURRENCY=5
PROCESSING_MIN_MS=3000
PROCESSING_MAX_MS=15000
QUEUE_MAX_ATTEMPTS=5
# Recovery sweeper: re-enqueue messages stuck in `received` (lost before processing)
# or `processing` (worker died mid-flight). Processing threshold must exceed
# worst-case processing + retry budget (~ PROCESSING_MAX_MS * QUEUE_MAX_ATTEMPTS).
SWEEPER_INTERVAL_MS=15000
SWEEPER_STUCK_AFTER_MS=10000
SWEEPER_PROCESSING_STUCK_AFTER_MS=120000
# Per-conversation ordering lock TTL
CONVERSATION_LOCK_TTL_MS=30000

# ---- Frontend ----
FRONTEND_PORT=8080
# Browser-facing API base (host port, not compose hostname)
VITE_API_BASE_URL=http://localhost:3000
