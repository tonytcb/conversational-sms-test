{
  "name": "sms-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Conversational SMS backend — Fastify API + BullMQ worker (clean architecture)",
  "type": "commonjs",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev:api": "tsx watch src/entrypoints/api.ts",
    "dev:worker": "tsx watch src/entrypoints/worker.ts",
    "start:api": "node dist/entrypoints/api.js",
    "start:worker": "node dist/entrypoints/worker.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node dist/infrastructure/db/migrate.js",
    "db:migrate:dev": "tsx src/infrastructure/db/migrate.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/formbody": "^8.0.1",
    "bullmq": "^5.34.0",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.2",
    "@testcontainers/redis": "^12.0.2",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
